# ── MyAgentMail (required) ─────────────────────────────────────────────
# Get yours at https://myagentmail.com — sign up, copy the master key
# from /dashboard. Free trial includes 2 inboxes.
MYAGENTMAIL_API_KEY=tk_your_key_here
# Optional. Defaults to https://myagentmail.com. Override for self-hosted
# or local dev.
MYAGENTMAIL_BASE_URL=https://myagentmail.com

# ── Default inbox (required for first-run scaffold) ────────────────────
# The username portion of the inbox the app should send from. The first
# time the app starts it will create this inbox via the MyAgentMail API
# if it doesn't exist yet (e.g. "scout" → scout@myagentmail.com).
MYAGENTMAIL_DEFAULT_INBOX=scout

# ── Webhook secret (recommended) ────────────────────────────────────────
# When you create a managed signal at /managed-signals, MyAgentMail returns
# a signing secret (whsec_...). Paste it here so we can verify HMAC
# signatures on incoming /api/webhook payloads. Without it, the route
# accepts unsigned payloads (dev mode only).
MYAGENTMAIL_WEBHOOK_SECRET=

# ── OpenAI (required for drafting messages locally) ─────────────────────
# Used to draft personalized outreach copy after a managed signal fires
# the webhook. Classification (filtering noise, scoring intent) is now
# done server-side by MyAgentMail — this is just for the message draft.
OPENAI_API_KEY=sk-...
# Optional. Defaults to gpt-4.1-mini-2025-04-14 (cheap + fast; the older
# gpt-4o-mini is deprecated). Override with gpt-4.1, gpt-5, etc. for
# higher-quality drafts.
OPENAI_MODEL=gpt-4.1-mini-2025-04-14

# ── RocketReach (optional — lead enrichment) ────────────────────────────
# If unset, the /leads page only supports manual lead entry.
ROCKETREACH_API_KEY=

# ── App ─────────────────────────────────────────────────────────────────
# Local-only sqlite path. Change if you want to persist outside the repo.
DATABASE_PATH=./data/outreach.db

# Cron token — only needed if you use the legacy local poller at /signals.
# The recommended flow uses MyAgentMail's managed signal API, which polls
# server-side and pushes matches to /api/webhook. No cron required.
CRON_SECRET=change-me

# Approval mode — "manual" (default, recommended) requires you to click
# Approve in the queue before any action fires. "auto" sends as soon as
# the agent decides — only use this if you fully trust the prompts.
APPROVAL_MODE=manual
